# LLM: set AI_PROVIDER to anthropic | openai | gemini | minimax (optional — auto-picks first key present)
# AI_PROVIDER=anthropic
# AI_MODEL=...          # optional override; else use provider-specific model env below
# AI_MAX_TOKENS=2048    # optional; else CLAUDE_MAX_TOKENS or default 2048

# Anthropic — console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# OpenAI — platform.openai.com
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini — aistudio.google.com/apikey (GEMINI_API_KEY or GOOGLE_API_KEY)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# MiniMax — OpenAI-compatible API (api.minimax.io or api.minimax.chat per your account)
# MINIMAX_API_KEY=
# MINIMAX_API_BASE=https://api.minimax.chat/v1
# MINIMAX_MODEL=MiniMax-Text-01
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_DEFAULT_FARM_ID=farm-001
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FARM_EMAIL=farmer@example.com
OPEN_METEO_URL=https://api.open-meteo.com/v1/forecast
DATABASE_PATH=backend/farmstock.db

# Stripe (get keys from dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MONTHLY_PRICE_ID=price_...
STRIPE_ANNUAL_PRICE_ID=price_...
APP_URL=http://localhost:5173

# JWT
JWT_SECRET_KEY=change-me-to-a-random-32-char-secret
JWT_EXPIRE_MINUTES=10080
